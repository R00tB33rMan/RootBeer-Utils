{
  "schemaVersion": 1,
  "id": "rootbeer_utils",
  "version": "${version}",
  "name": "RootBeer-Utils",
  "description": "Various useful utilities!",
  "authors": [
    "R00tB33rMan"
  ],
  "contact": {
    "homepage": "https://example.invalid/rootbeer-utils",
    "sources":  "https://example.invalid/rootbeer-utils"
  },
  "license": "MIT",
  "icon": "assets/rootbeerutils/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.rootbeerutils.client.zoom.ZoomClient",
      "com.rootbeerutils.client.shulkerbox.ShulkerBoxPreview",
      "com.rootbeerutils.client.quickpack.QuickPackClient"
    ]
  },
  "mixins": [
    {
      "config": "rootbeerutils.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api":   ">=${fabric_version}",
    "minecraft":    "~${minecraft_version}",
    "java":         ">=25"
  }
}
